{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NetLab",
  "version": "0.1.0-alpha.1",
  "identifier": "cc.vust.netlab",
  "build": {
    "beforeDevCommand": "pnpm web:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm web:build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "shortDescription": "netlab",
    "longDescription": "Desktop helper app.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4Rjc0OERCMUJEMUUxNzIKUldSeTRkRWIyMGozR0RjZVk2V0ZLeEFoUWR6V2dmUGxPeG4xLzdIMWFlaXVTZWt0UnpuTGp0cGQK",
      "endpoints": [
        "https://netlab.vust.cc/api/update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "fs": {
      "requireLiteralLeadingDot": false
    }
  },
  "app": {
    "windows": [
      {
        "title": "NetLab",
        "width": 1024,
        "height": 768,
        "minWidth": 1024,
        "minHeight": 768,
        "decorations": false,
        "visible": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": {
        "img-src": "'self' asset: http://asset.localhost"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      }
    }
  }
}
